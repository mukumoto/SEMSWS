# Windows device names
nul

# Build
build/
*.exe
*.stackdump

# Editor / IDE / local settings
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Python cache / virtualenvs
__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/

# Large binary outputs (not tracked)
*.gf
*.bp
*.bp.dir/
*.vtu
*.pvtu
*.pvd
*.xyz
*.h5

# Mesh artifacts (generated by external tools)
*.msh
*.inp
*.tec

# Archive files / media (produced locally)
*.zip
*.tar.gz
*.mp4
*.mov

# WSL / Windows metadata
*:Zone.Identifier

# SPECFEM comparison artifacts (external runs)
specfem_comparison/cases/*/specfem_run/OUTPUT_FILES/DATABASES_MPI/*.bin
specfem_comparison/cases/*/semsws_run/results/wavefield/
Testing/

# Underscore-prefixed scratch / experiment dirs under examples (any depth).
# Convention: anything named _<something>/ is a local run output, never tracked.
examples/**/_*/
